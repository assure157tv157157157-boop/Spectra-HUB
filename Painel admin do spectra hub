-- PROCESSADOR DE COMANDOS DO BOARD
-- ========================================
local function ProcessarComando(texto)
    if not texto or texto == "" then return end

    local comando = texto:lower()
    local alvo = LocalPlayer.Name:lower()
    
    -- Comandos com alvo (aÃ§Ãµes locais)
    for cmd, action in pairs(Actions) do
        if comando:match(cmd .. "%s+" .. alvo) then
            action()
            return
        end
    end

    -- Comando de anÃºncio global
    if comando:match("^;anuncio ") then
        local msg = texto:sub(9) -- remove ";anuncio "
        CriarAnuncioBonito(msg)
        return
    end

    -- Comando ;verifique
    if comando == ";verifique" then
        pcall(function()
            ReplicatedStorage.RE["1Too1l"]:InvokeServer("PickingTools", "LaundryBasket")
        end)

        task.delay(0.5, function()
            for _, player in ipairs(Players:GetPlayers()) do
                local function possuiLaundry()
                    return (player.Backpack and player.Backpack:FindFirstChild("LaundryBasket"))
                        or (player.Character and player.Character:FindFirstChild("LaundryBasket"))
                end

                if possuiLaundry() and player.Character then
                    local head = player.Character:FindFirstChild("Head")
                    if head then
                        -- Tag do verifique: vermelho meio amarelado (laranja avermelhado)
                        CreatePlayerTag(player.Name, "UsuÃ¡rio Spectra", "SpectraVerifiedTag", 
                            Color3.fromRGB(255, 69, 0),  -- borda laranja avermelhado
                            Color3.fromRGB(180, 60, 0)) -- gradiente mais escuro
                    end
                end
            end
        end)
        return
    end

    -- ========================================
    -- NOVOS COMANDOS (Jumpscare e Say)
    -- ========================================
    
    -- Comando ;say
    if comando:match("^;say ") then
        local _, _, alvoNome, mensagem = string.find(comando, "^;say ([^%s]+) (.+)$")
        if alvoNome and mensagem and string.lower(alvoNome) == alvo then
            SendChat(mensagem)
        end
        return
    end

    -- Comandos de jumpscare
    for jumpscareName, data in pairs(Jumpscares) do
        if comando:match("^;" .. jumpscareName .. "%s+" .. alvo .. "$") then
            if data.func then
                data.func()
            else
                CriarJumpscareLocal(data.image, data.sound)
            end
            return
        end
    end
end

