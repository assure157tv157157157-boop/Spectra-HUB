local function EnviarBoard(cmd, target)
    if not target or target == "" then
        BoardRemote:FireServer("ReturningBoardName", BoardCount, ";" .. cmd)
    else
        BoardRemote:FireServer("ReturningBoardName", BoardCount, ";" .. cmd .. " " .. target:lower())
    end
end

